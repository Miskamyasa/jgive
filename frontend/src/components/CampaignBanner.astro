---
// Campaign banner / hero with a progress region.
// A React progress island (ProgressIsland) mounts into [data-progress-island]
// and renders live campaign progress from the API. The values below are passed
// as initial/fallback props so the island shows sensible numbers before the
// fetch resolves.
import ProgressIsland from './ProgressIsland.tsx';
import DonationForm from './DonationForm.tsx';

const raised = 1071976;
const goal = 5000000;
const donors = 3530;
const percent = Math.round((raised / goal) * 100);

const flags = [
	{ code: 'US', label: 'United States' },
	{ code: 'IL', label: 'Israel' },
	{ code: 'UK', label: 'United Kingdom' },
	{ code: 'CA', label: 'Canada' },
];
---

<section class="campaign-banner" aria-labelledby="campaign-title">
	<!--
		Progress island mount point.
		The React ProgressIsland below hydrates this container, rendering live
		campaign progress from the API. The data-* attributes mirror the initial
		fallback values handed to the island as props.
	-->
	<div
		class="progress-region"
		data-progress-island
		data-raised={raised}
		data-goal={goal}
		data-donors={donors}
		data-percent={percent}
	>
		<ProgressIsland
			client:load
			raised={raised}
			goal={goal}
			donors={donors}
			percent={percent}
		/>
	</div>

	<div class="cta-cluster">
		<span class="donate-btn" role="link" aria-disabled="true">Donate</span>
		<button type="button" class="ambassador-btn" disabled aria-disabled="true">
			Join as ambassadors
		</button>

		<p class="tax-line">
			<span class="info-badge" aria-hidden="true">i</span>
			<span class="flags" aria-hidden="true">
				{flags.map((flag) => <span class="flag" title={flag.label}>{flag.code}</span>)}
			</span>
			<span>Tax-deductible donation</span>
		</p>

		<div class="share-row" aria-label="Share (placeholder)">
			<span class="share-icon" title="Facebook" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"></path></svg>
			</span>
			<span class="share-icon" title="WhatsApp" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.5A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.9.9-2.8-.2-.3A8 8 0 1 1 12 20zm4.4-6c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.5.1l-.7.9c-.1.2-.3.2-.5.1a6.6 6.6 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.6.3a3 3 0 0 0-.9 2.2c0 1.3 1 2.6 1.1 2.7.1.2 1.8 2.8 4.4 3.9 1.6.7 2.2.7 3 .6.5 0 1.4-.6 1.6-1.1.2-.6.2-1 .1-1.1 0-.1-.2-.2-.5-.3z"></path></svg>
			</span>
			<span class="share-icon" title="X" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.2 2H21l-6.4 7.4L22 22h-6.6l-4.6-6-5.3 6H2.7l6.9-7.9L2 2h6.7l4.2 5.5L18.2 2zm-1.2 18h1.8L7.1 4H5.2l11.8 16z"></path></svg>
			</span>
			<span class="share-icon" title="Copy link" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"></path><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"></path></svg>
			</span>
		</div>

		<DonationForm client:visible />
	</div>

	<div class="campaign-heading">
		<h1 id="campaign-title">The Orange Garden</h1>
		<p class="campaign-subtitle">
			In memory of the Bibas family and the children of October 7
		</p>
	</div>
</section>

<style>
	.campaign-banner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	/* Progress region */
	.progress-region {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
	}

	.stats-top,
	.stats-bottom {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.raised-label {
		color: var(--progress-green);
		font-size: 1.5rem;
		font-weight: 600;
	}

	.raised-label strong {
		font-weight: 800;
	}

	.raised-amount {
		color: var(--progress-green);
		font-size: clamp(2.5rem, 6vw, 4rem);
		font-weight: 800;
		line-height: 1;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.raised-amount .shekel {
		font-size: 0.7em;
	}

	/* Progress bar with orange heart marker */
	.progress-bar {
		position: relative;
		width: 100%;
	}

	.progress-track {
		width: 100%;
		height: 14px;
		border-radius: 999px;
		background: #b8b8b8;
		overflow: hidden;
	}

	.progress-fill {
		height: 100%;
		background: var(--progress-green);
		border-radius: 999px 0 0 999px;
	}

	.heart-marker {
		position: absolute;
		top: 50%;
		transform: translate(-50%, -50%);
		color: var(--heart-orange);
		font-size: 2rem;
		line-height: 1;
		pointer-events: none;
	}

	.stats-bottom {
		color: var(--progress-green);
		font-size: 1.4rem;
		font-weight: 600;
	}

	.goal-line .shekel,
	.donor-line {
		white-space: nowrap;
	}

	/* CTA cluster */
	.cta-cluster {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.85rem;
		max-width: 520px;
		width: 100%;
		margin: 0 auto;
	}

	.donate-btn {
		width: 100%;
		text-align: center;
		text-decoration: none;
		color: #fff;
		background: var(--accent-magenta-bright);
		padding: 0.85rem 1.5rem;
		border-radius: 999px;
		font-weight: 600;
		font-size: 1.1rem;
	}

	.donate-btn:hover {
		background: var(--accent-magenta);
	}

	.ambassador-btn {
		width: 100%;
		text-align: center;
		font: inherit;
		font-weight: 600;
		color: var(--accent-magenta-bright);
		background: #fff;
		border: 1px solid var(--accent-magenta-bright);
		padding: 0.85rem 1.5rem;
		border-radius: 999px;
		cursor: default;
	}

	.tax-line {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin: 0.25rem 0 0;
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	.info-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		background: var(--text-muted);
		color: #fff;
		font-size: 0.7rem;
		font-weight: 700;
		font-style: italic;
	}

	.flags {
		display: inline-flex;
		gap: 0.25rem;
	}

	.flag {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 22px;
		height: 16px;
		padding: 0 2px;
		border: 1px solid var(--border);
		border-radius: 2px;
		background: #fff;
		font-size: 0.6rem;
		font-weight: 700;
		color: var(--text);
	}

	.share-row {
		display: inline-flex;
		align-items: center;
		gap: 1.5rem;
		margin-top: 0.25rem;
	}

	.share-icon {
		display: inline-flex;
		color: var(--text-muted);
	}

	.share-icon[title='Facebook'] {
		color: #1877f2;
	}

	.share-icon[title='WhatsApp'] {
		color: #25d366;
	}

	.share-icon[title='X'] {
		color: #1da1f2;
	}

	/* Campaign heading */
	.campaign-heading {
		text-align: center;
	}

	.campaign-heading h1 {
		margin: 0 0 0.5rem;
		font-size: 2rem;
		font-weight: 800;
		letter-spacing: 0.05em;
	}

	.campaign-subtitle {
		margin: 0;
		color: var(--text-muted);
		font-size: 1rem;
	}

	@media (min-width: 768px) {
		.campaign-banner {
			grid-template-columns: 1fr 1fr;
			align-items: start;
		}

		.progress-region {
			grid-column: 1 / -1;
		}

		.cta-cluster {
			margin: 0;
			align-items: stretch;
		}

		.campaign-heading {
			text-align: right;
		}
	}
</style>
