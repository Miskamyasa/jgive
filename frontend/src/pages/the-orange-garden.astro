---
import SiteLayout from '../layouts/SiteLayout.astro';
import CampaignBanner from '../components/CampaignBanner.astro';
import CampaignTabs from '../components/CampaignTabs.tsx';
---

<SiteLayout title="The Orange Garden — Jgive">
	<main class="campaign-page">
		<CampaignBanner />

		<section class="tabs-section" aria-label="Campaign details">
			<CampaignTabs client:visible />
		</section>
	</main>
</SiteLayout>

<style>
	.campaign-page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 1.5rem 3rem;
	}

	.tabs-section {
		margin-top: 1rem;
	}

	/* Panel typography — keep section content readable and centered within
	   the page container. */
	.tabs-section :global(.tabs__panel) {
		line-height: 1.65;
		color: var(--text);
	}

	.tabs-section :global(.tabs__panel h2) {
		font-size: 1.4rem;
		font-weight: 700;
		margin: 1.5rem 0 0.75rem;
	}

	.tabs-section :global(.tabs__panel h2:first-child) {
		margin-top: 0;
	}

	.tabs-section :global(.tabs__panel ul) {
		padding-left: 1.25rem;
	}

	.tabs-section :global(.tabs__panel li) {
		margin-bottom: 0.5rem;
	}

	.tabs-section :global(.tabs__panel blockquote) {
		margin: 1rem 0;
		padding: 0.75rem 1.25rem;
		border-left: 3px solid var(--accent-magenta);
		color: var(--text-muted);
		font-style: italic;
	}

	.tabs-section :global(.tabs__panel table) {
		width: 100%;
		border-collapse: collapse;
		margin-top: 1rem;
	}

	.tabs-section :global(.tabs__panel th),
	.tabs-section :global(.tabs__panel td) {
		text-align: left;
		padding: 0.6rem 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.tabs-section :global(.tabs__panel th) {
		font-weight: 700;
		color: var(--text-muted);
	}
</style>
