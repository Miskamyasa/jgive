---
interface Props {
	title?: string;
}

const { title = 'Jgive' } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<span class="brand" role="link" aria-disabled="true" aria-label="Jgive home">
				<span class="brand-text">Jgive</span>
				<span class="brand-heart" aria-hidden="true">&#9829;</span>
			</span>

			<nav class="primary-nav" aria-label="Primary">
				<span role="link" aria-disabled="true">Solutions</span>
				<span role="link" aria-disabled="true">About Us</span>
				<span role="link" aria-disabled="true">Products</span>
			</nav>

			<div class="header-actions">
				<button type="button" class="icon-btn" aria-label="Search">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<circle cx="11" cy="11" r="7"></circle>
						<line x1="16.5" y1="16.5" x2="21" y2="21"></line>
					</svg>
				</button>

				<button type="button" class="support-btn">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M4 13v-1a8 8 0 0 1 16 0v1"></path>
						<rect x="2" y="13" width="4" height="6" rx="1"></rect>
						<rect x="18" y="13" width="4" height="6" rx="1"></rect>
					</svg>
					<span>Support</span>
				</button>

				<button type="button" class="lang-selector">
					EN | ILS
					<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<polyline points="6 9 12 15 18 9"></polyline>
					</svg>
				</button>

				<span class="login-link" role="link" aria-disabled="true">Login / Join</span>

				<span class="donate-cta" role="link" aria-disabled="true">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
						<path d="M12 21s-7.5-4.9-9.7-9.3C.7 8.4 2.6 5 6 5c2 0 3.2 1.1 4 2 .8-.9 2-2 4-2 3.4 0 5.3 3.4 3.7 6.7C19.5 16.1 12 21 12 21z"></path>
					</svg>
					Donate
				</span>
			</div>
		</header>

		<slot />

		<footer class="site-footer">
			<div class="footer-columns">
				<div class="footer-col">
					<h2>Usage</h2>
					<ul>
						<li><span role="link" aria-disabled="true">Support</span></li>
						<li><span role="link" aria-disabled="true">Contact</span></li>
						<li><span role="link" aria-disabled="true">Fees</span></li>
						<li><span role="link" aria-disabled="true">Donate</span></li>
					</ul>
				</div>

				<div class="footer-col">
					<h2>Products</h2>
					<ul>
						<li><span role="link" aria-disabled="true">Jgive Platinum</span></li>
						<li><span role="link" aria-disabled="true">Jgive PRO</span></li>
						<li><span role="link" aria-disabled="true">Jgive Business</span></li>
						<li><span role="link" aria-disabled="true">GiveCard</span></li>
						<li><span role="link" aria-disabled="true">Stock Donations</span></li>
					</ul>
				</div>

				<div class="footer-col">
					<h2>Join Us</h2>
					<ul>
						<li><span role="link" aria-disabled="true">Donors</span></li>
						<li><span role="link" aria-disabled="true">NGOs</span></li>
						<li><span role="link" aria-disabled="true">Companies</span></li>
						<li><span role="link" aria-disabled="true">Careers</span></li>
					</ul>
				</div>

				<div class="footer-col">
					<h2>About</h2>
					<ul>
						<li><span role="link" aria-disabled="true">Our Story</span></li>
						<li><span role="link" aria-disabled="true">Social Directory</span></li>
						<li><span role="link" aria-disabled="true">Investment Committee</span></li>
						<li><span role="link" aria-disabled="true">Research &amp; Data</span></li>
						<li><span role="link" aria-disabled="true">Information Security</span></li>
					</ul>
				</div>

				<div class="footer-brand">
					<span class="brand" role="link" aria-disabled="true" aria-label="Jgive home">
						<span class="brand-text">Jgive</span>
						<span class="brand-heart" aria-hidden="true">&#9829;</span>
					</span>
					<p class="copyright">&copy; Jgive, Keren Asor (NPO) 2026</p>
				</div>
			</div>

			<nav class="footer-legal" aria-label="Legal">
				<span role="link" aria-disabled="true">Cookie Settings</span>
				<span role="link" aria-disabled="true">Terms of Use</span>
				<span role="link" aria-disabled="true">NGO Terms of Use</span>
				<span role="link" aria-disabled="true">Privacy Policy</span>
				<span role="link" aria-disabled="true">Accessibility Statement</span>
			</nav>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--accent-magenta: #c026d3;
		--accent-magenta-bright: #d400ff;
		--progress-green: #15803d;
		--heart-orange: #f59e0b;
		--text: #1f2937;
		--text-muted: #6b7280;
		--page-bg: #f9fafb;
		--border: #e5e7eb;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial,
			sans-serif;
		color: var(--text);
		background: var(--page-bg);
	}
</style>

<style>
	.brand {
		display: inline-flex;
		align-items: flex-start;
		text-decoration: none;
		color: var(--text);
		font-weight: 700;
		font-size: 1.6rem;
		line-height: 1;
	}

	.brand-heart {
		color: var(--accent-magenta-bright);
		font-size: 0.7rem;
		margin-left: 1px;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		padding: 1rem 1.5rem;
		background: #fff;
		border-bottom: 1px solid var(--border);
	}

	.primary-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
	}

	.primary-nav [role='link'] {
		text-decoration: none;
		color: var(--text);
		font-weight: 500;
	}

	.primary-nav [role='link']:hover {
		color: var(--accent-magenta);
	}

	.header-actions {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.icon-btn,
	.support-btn,
	.lang-selector {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		font: inherit;
		color: var(--text);
	}

	.support-btn:hover,
	.lang-selector:hover,
	.icon-btn:hover {
		color: var(--accent-magenta);
	}

	.lang-selector {
		font-weight: 500;
	}

	.login-link {
		text-decoration: none;
		color: var(--accent-magenta);
		font-weight: 600;
	}

	.donate-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		text-decoration: none;
		color: #fff;
		background: var(--accent-magenta-bright);
		padding: 0.6rem 1.4rem;
		border-radius: 999px;
		font-weight: 600;
	}

	.donate-cta:hover {
		background: var(--accent-magenta);
	}

	.site-footer {
		background: #fff;
		border-top: 1px solid var(--border);
		padding: 3rem 1.5rem 2rem;
	}

	.footer-columns {
		display: flex;
		flex-wrap: wrap;
		gap: 2.5rem;
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-col {
		flex: 1 1 140px;
	}

	.footer-col h2 {
		margin: 0 0 1rem;
		font-size: 1rem;
		font-weight: 700;
	}

	.footer-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-col [role='link'] {
		text-decoration: none;
		color: var(--text-muted);
	}

	.footer-col [role='link']:hover {
		color: var(--accent-magenta);
	}

	.footer-brand {
		flex: 1 1 200px;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.footer-brand .brand {
		font-size: 2.4rem;
	}

	.copyright {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.85rem;
	}

	.footer-legal {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		max-width: 1200px;
		margin: 2rem auto 0;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
	}

	.footer-legal [role='link'] {
		text-decoration: none;
		color: var(--text-muted);
		font-size: 0.85rem;
	}

	.footer-legal [role='link']:hover {
		color: var(--accent-magenta);
	}

	@media (max-width: 640px) {
		.site-header {
			justify-content: center;
		}
	}
</style>
